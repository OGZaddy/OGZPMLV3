# All strategies backtest profile
# Usage: DOTENV_CONFIG_PATH=.env.backtest-all node run-empire-v2.js

# Strategy toggles - all enabled
ENABLE_RSI=true
ENABLE_MASR=true
ENABLE_EMA=true
ENABLE_LIQSWEEP=true
ENABLE_REGIME=true
ENABLE_MTF=true
ENABLE_TPO=true

# Execution
CANDLE_SOURCE=file
CANDLE_FILE=tuning/full-45k.json
EXECUTION_MODE=backtest
DIRECTION_FILTER=long_only

# Skip heavy components for speed
ENABLE_TRAI=false
ENABLE_DASHBOARD=false
ENABLE_NOTIFICATIONS=false
