# RSI-only backtest profile
# Usage: DOTENV_CONFIG_PATH=.env.backtest-rsi node run-empire-v2.js

# Strategy toggles - RSI only
ENABLE_RSI=true
ENABLE_MASR=false
ENABLE_EMA=false
ENABLE_LIQSWEEP=false
ENABLE_REGIME=false
ENABLE_MTF=false
ENABLE_TPO=false

# Execution
CANDLE_SOURCE=file
CANDLE_FILE=tuning/full-45k.json
EXECUTION_MODE=backtest
DIRECTION_FILTER=long_only

# Skip heavy components for speed
ENABLE_TRAI=false
ENABLE_DASHBOARD=false
ENABLE_NOTIFICATIONS=false
