# Paper trading profile - live feed, simulated execution
# Usage: DOTENV_CONFIG_PATH=.env.paper node run-empire-v2.js

# Strategy toggles - all enabled
ENABLE_RSI=true
ENABLE_MASR=true
ENABLE_EMA=true
ENABLE_LIQSWEEP=true
ENABLE_REGIME=true
ENABLE_MTF=true
ENABLE_TPO=true

# Execution
CANDLE_SOURCE=live
EXECUTION_MODE=paper
DIRECTION_FILTER=long_only

# Components
ENABLE_TRAI=false
ENABLE_DASHBOARD=true
ENABLE_NOTIFICATIONS=true
ENABLE_RISK=true
