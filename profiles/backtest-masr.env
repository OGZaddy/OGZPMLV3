# MADynamicSR-only backtest profile
# Usage: DOTENV_CONFIG_PATH=.env.backtest-masr node run-empire-v2.js

# Strategy toggles - MASR only
ENABLE_RSI=false
ENABLE_MASR=true
ENABLE_EMA=false
ENABLE_LIQSWEEP=false
ENABLE_REGIME=false
ENABLE_MTF=false
ENABLE_TPO=false

# Execution
CANDLE_SOURCE=file
CANDLE_FILE=tuning/full-45k.json
EXECUTION_MODE=backtest
DIRECTION_FILTER=long_only

# Skip heavy components for speed
ENABLE_TRAI=false
ENABLE_DASHBOARD=false
ENABLE_NOTIFICATIONS=false
