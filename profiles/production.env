# Production live trading profile
# Usage: DOTENV_CONFIG_PATH=.env.production node run-empire-v2.js
# WARNING: Real money at risk!

# Strategy toggles - all enabled
ENABLE_RSI=true
ENABLE_MASR=true
ENABLE_EMA=true
ENABLE_LIQSWEEP=true
ENABLE_REGIME=true
ENABLE_MTF=true
ENABLE_TPO=true

# Execution - LIVE TRADING
CANDLE_SOURCE=live
EXECUTION_MODE=live
DIRECTION_FILTER=long_only

# All components enabled
ENABLE_TRAI=false
ENABLE_DASHBOARD=true
ENABLE_NOTIFICATIONS=true
ENABLE_RISK=true
